# Variables de entorno del proyecto. Copiar como .env y ajustar valores.
# cp .env.example .env

# Base de datos PostgreSQL
DB_USERNAME=german
DB_PASSWORD=Golondrina86@

# JWT
JWT_SECRET=cambia-esto-por-un-secreto-seguro-de-al-menos-64-caracteres-en-prod
JWT_EXPIRATION_MINUTES=60

# Frontend (URL del backend para el build de Docker)
VITE_API_BASE_URL=http://localhost:8080

# Recuperacion de contrasena
PASSWORD_RESET_FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_EXPOSE_TOKEN_IN_RESPONSE=true

# SMTP (opcional, para enviar email real)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@wallet.local
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
